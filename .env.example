# Supabase — get these from your project at https://supabase.com/dashboard
# Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# ── Notifications (optional but recommended) ──────────────────────────────
# Email via Resend — https://resend.com/api-keys
# Leave RESEND_API_KEY / QUOTE_NOTIFICATION_TO empty to skip email.
RESEND_API_KEY=re_your_api_key
# Where new-quote emails are sent (the business inbox):
QUOTE_NOTIFICATION_TO=owner@example.com
# Sender. Must be a verified domain in Resend. The default sandbox sender
# (onboarding@resend.dev) only delivers to your own Resend account email.
QUOTE_NOTIFICATION_FROM=Zero Maintenance <quotes@yourdomain.com>

# SMS via Twilio — https://console.twilio.com
# Leave any of these empty to skip SMS.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
# Your Twilio phone number (E.164 format), e.g. +15551234567
TWILIO_FROM_NUMBER=+15551234567
# Where new-quote texts are sent (the business's phone), E.164 format:
QUOTE_NOTIFICATION_SMS_TO=+15559876543
